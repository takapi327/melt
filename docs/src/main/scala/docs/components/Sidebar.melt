<script lang="scala" props="Props">
import docs.I18n

case class Props(basePath: String = "", lang: String = "en", section: String = "", slug: String = "")

val base = props.basePath + "/" + props.lang
val t    = I18n(props.lang)
val ss   = t.sidebarSections

def isActive(sec: String, s: String): Boolean = props.section == sec && props.slug == s

val introItems    = List("introduction", "installation", "quick-start")
val basicsItems   = List("components", "template-syntax", "reactivity", "computed", "effects", "events", "lifecycle")
val advancedItems = List("control-flow", "special-elements", "transitions", "trusted-html", "css", "testing")
val serverItems   = List("routing", "ssr", "ssg", "adapters")
val apiItems      = List("template-syntax", "runtime", "meltkit", "meltkit-ssg", "compiler", "sbt-plugin")
val exampleItems  = List("counter", "todo-app")
</script>

<aside class="sidebar">
  <div class="sidebar-section">
    <h4>{ss.intro}</h4>
    {introItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("guide", item)} href={base + "/guide/" + item}>{t.guideLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <h4>{ss.basics}</h4>
    {basicsItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("guide", item)} href={base + "/guide/" + item}>{t.guideLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <h4>{ss.advanced}</h4>
    {advancedItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("guide", item)} href={base + "/guide/" + item}>{t.guideLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <h4>{ss.server}</h4>
    {serverItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("guide", item)} href={base + "/guide/" + item}>{t.guideLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <h4>{t.nav.api}</h4>
    {apiItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("api", item)} href={base + "/api/" + item}>{t.apiLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <h4>{t.nav.examples}</h4>
    <a class="sidebar-link" class:active={props.section == "examples" && props.slug == ""} href={base + "/examples"}>All Examples</a>
    {exampleItems.map((item: String) =>
      <a class="sidebar-link" class:active={isActive("examples", item)} href={base + "/examples/" + item}>{t.exampleLinks(item)}</a>
    )}
  </div>

  <div class="sidebar-section">
    <a class="sidebar-link" class:active={props.section == "changelog"} href={base + "/changelog"}>{t.nav.changelog}</a>
  </div>
</aside>

