  color: var(--fg-dim);
  padding: 0 10px;
  margin-bottom: 8px;
}
.sidebar-link {
  display: block;
  padding: 7px 10px;
  margin: 1px 0;
  font-size: 14.5px;
  color: var(--fg-mute);
  border-radius: 4px;
  border-left: 2px solid transparent;
  transition: all .12s;
}
.sidebar-link:hover {
  color: var(--fg);
