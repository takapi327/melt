{
  "name": "@melt/vite-plugin",
  "version": "0.1.0",
  "description": "Official Vite plugin for the Melt framework",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vite": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "@scala-js/vite-plugin-scalajs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.4.0",
    "vitest": "^4.1.5"
  }
}
